# ============================================
# GUARD — variáveis de ambiente
# Copie este arquivo para .env e preencha
# NUNCA commite o arquivo .env no repositório
# ============================================

# Banco de dados
DB_NAME=guarddb
DB_USER=guard_user
DB_PASSWORD=guard_pass

# JPA (create | validate | update | none)
# Em produção usar: validate
DDL_AUTO=validate

# JWT — expirações em segundos
JWT_ACCESS_TOKEN_EXPIRATION=900
JWT_REFRESH_TOKEN_EXPIRATION=604800

# Os arquivos PEM são montados via volume Docker
# Caminho na VPS: ~/certs/guard/private.pem e ~/certs/guard/public.pem
# Caminho no container: /app/certs/ (configurado automaticamente no docker-compose)